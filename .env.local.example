NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role (bypasses RLS — server only, never expose)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend email — already used for payment reminders
RESEND_API_KEY=re_...

# Claude AI — already installed (@anthropic-ai/sdk)
ANTHROPIC_API_KEY=sk-ant-...

# Cron job auth
CRON_SECRET=generate-a-random-secret-here

# Property News Digest
NEWS_FETCH_ENABLED=true
NEWS_DIGEST_SEND_ENABLED=false
ADMIN_TEST_EMAIL=your@email.com

# App URL (used in email links)
NEXT_PUBLIC_APP_URL=https://proptrust.co.za
