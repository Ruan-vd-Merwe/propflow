# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Site URL ──────────────────────────────────────────────────────────────────
# Used for auth email redirect URLs (confirmation, password reset).
# Must match Supabase → Authentication → URL Configuration → Site URL.
# Production:
NEXT_PUBLIC_SITE_URL=https://proptrust.co.za
# Local dev (add to .env.local):
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Resend (transactional email) ──────────────────────────────────────────────
# Used for payment, lease, and introduction notification emails.
# Supabase Auth confirmation/reset emails are configured separately in the
# Supabase dashboard (Authentication → SMTP settings).
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=PropTrust <notifications@proptrust.co.za>

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
# Required for WhatsApp tenant messaging (rent reminders, introductions, etc.)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Twilio sandbox number (sandbox) or approved sender (production):
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Supabase webhook secret ────────────────────────────────────────────────────
SUPABASE_HOOK_SECRET=your_hook_secret_here
