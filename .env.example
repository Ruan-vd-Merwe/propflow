# ── Site URL ──────────────────────────────────────────────────────────────────
# Must match Supabase → Authentication → URL Configuration → Site URL.
# Add to Vercel environment variables + local .env.local for dev.
NEXT_PUBLIC_SITE_URL=https://proptrust.co.za

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Resend (transactional email — payment, lease, introduction notifications) ─
# NOTE: Supabase Auth emails (confirmation, reset) use Supabase SMTP settings,
# not this key. Configure SMTP in Supabase Dashboard → Auth → SMTP Settings.
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=PropTrust <notifications@proptrust.co.za>

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Supabase webhook secret ────────────────────────────────────────────────────
SUPABASE_HOOK_SECRET=your_hook_secret_here
