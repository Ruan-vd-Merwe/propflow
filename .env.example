# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Site URL (used for auth email redirect) ───────────────────────────────────
# Production: https://proptrust.co.za
# Local dev:  http://localhost:3000
# Must match Supabase → Authentication → URL Configuration → Site URL
NEXT_PUBLIC_SITE_URL=https://proptrust.co.za

# Supabase Auth URL Configuration (set in Supabase dashboard, not here):
#   Site URL:      https://proptrust.co.za
#   Redirect URLs: https://proptrust.co.za/auth/callback
#                  http://localhost:3000/auth/callback

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=PropTrust <notifications@proptrust.co.za>

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
# Required for WhatsApp tenant messaging
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Twilio sandbox sender (sandbox) or approved sender (production):
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Supabase webhook secret (if using Supabase hooks)
SUPABASE_HOOK_SECRET=your_hook_secret_here

# ── Twilio / WhatsApp (optional — only used for UI display, never a secret) ──
# Set this to a masked display value for the settings page status badge.
# Do NOT put the real auth token here.
# NEXT_PUBLIC_TWILIO_WHATSAPP_DISPLAY=whatsapp:+1415*****886
